{
  "name": "mykemeynell/inkstone",
  "description": "Generate beautiful deployable Laravel documentation sites from Markdown with minimal configuration.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Inkstone\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Inkstone\\Tests\\": "tests"
    }
  },
  "bin": [
    "bin/inkstone"
  ],
  "require": {
    "php": ">=8.2",
    "illuminate/cache": "^11.0|^12.0|^13.0",
    "illuminate/config": "^11.0|^12.0|^13.0",
    "illuminate/console": "^11.0|^12.0|^13.0",
    "illuminate/container": "^11.0|^12.0|^13.0",
    "illuminate/database": "^11.0|^12.0|^13.0",
    "illuminate/events": "^11.0|^12.0|^13.0",
    "illuminate/filesystem": "^11.0|^12.0|^13.0",
    "illuminate/log": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "illuminate/view": "^11.0|^12.0|^13.0",
    "league/commonmark": "^2.8",
    "phiki/phiki": "^2.0",
    "symfony/filesystem": "^7.0",
    "symfony/finder": "^7.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^11.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11"
  },
  "scripts": {
    "test": "./vendor/bin/phpunit",
    "test:coverage": "\"$(which php)\" -dxdebug.coverage_enable=1 -dxdebug.mode=coverage ./vendor/bin/phpunit --coverage-html coverage",
    "test:coverage:serve": "composer test:coverage && open coverage/index.html",
    "lint": "./vendor/bin/pint --test",
    "lint:fix": "./vendor/bin/pint",
    "analyze": "./vendor/bin/phpstan analyse",
    "analyze:fix": "./vendor/bin/phpstan analyse --fix",
    "docs": "./vendor/bin/doctum.php update ./doctum.config.php",
    "docs:serve": "cd ./docs && php -S localhost:9091"
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "Inkstone\\Providers\\InkstoneServiceProvider"
      ],
      "aliases": {
        "Inkstone": "Inkstone\\Facades\\DocsGenerator"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
